{
  "manifest_version": 3,
  "name": "Playwright Locator Helper",
  "version": "2.0.0",
  "description": "Generate robust Playwright locators for web elements with advanced ARIA support and semantic analysis",
  "author": "Alien Hu",
    
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "notifications",
    "storage"
  ],
  
  "optional_permissions": [
    "tabs"
  ],
  
  "host_permissions": [
    "<all_urls>"
  ],
  
  "action": {
    "default_title": "Open Playwright Locator Helper",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file://*/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_start",
      "all_frames": false,
      "match_about_blank": false
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "start-element-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Start element selection mode"
    },
    "open-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open side panel"
    }
  },
  
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  
  "minimum_chrome_version": "116"
}